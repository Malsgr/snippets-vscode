{
    "fetch GET": {
        "prefix": "fetchGet",
        "body": [
            "async function fetchData(url) {",
            "    const response = await fetch(url);",
            "    const ${1|text,json|} = ${1:text:await response.text(),json:await response.json()};",
            "    return ${1:text,json};",
            "}"
        ],
        "description": "Función fetch GET con opción text/json",
        "scope": "javascript"
    },
    "fetch Body": {
        "prefix": "fetchBody",
        "body": [
            "async function sendData(url, data) {",
            "    const response = await fetch(url, {",
            "        method: ${1|POST,PUT,DELETE|},",
            "        headers: { 'Content-Type': 'application/json' },",
            "        body: JSON.stringify(data)",
            "    });",
            "    const ${2|text,json|} = ${2:text:await response.text(),json:await response.json()};",
            "    return ${2:text,json};",
            "}"
        ],
        "description": "fetch con método POST, PUT o DELETE",
        "scope": "javascript"
    },
    "createElement": {
        "prefix": "createElement",
        "body": [
            "const ${1:element} = document.createElement('${2:tag}');"
        ],
        "description": "Crea un elemento del DOM",
        "scope": "javascript"
    },
    "querySelector": {
        "prefix": "querySelector",
        "body": [
            "const ${1:element} = document.querySelector('${2:selector}');"
        ],
        "description": "Selecciona un elemento del DOM",
        "scope": "javascript"
    },
    "addEventListener": {
        "prefix": "addEventListener",
        "body": [
            "${1:element}.addEventListener('${2:click}', () => {",
            "    $0",
            "});"
        ],
        "description": "Añade un evento a un elemento",
        "scope": "javascript"
    }
}