{
    "SQL Create Table": {
        "prefix": "sqlcreate",
        "body": [
            "CREATE TABLE ${1:table_name} (",
            "    id ${2:INT} PRIMARY KEY${3: AUTO_INCREMENT},",
            "    ${4:column_name} ${5:VARCHAR(255)} NOT NULL,",
            "    ${6:created_at} TIMESTAMP DEFAULT CURRENT_TIMESTAMP",
            ");"
        ],
        "description": "Create table",
        "scope": "sql"
    },
    "SQL Select All": {
        "prefix": "sqlselect",
        "body": [
            "SELECT",
            "    ${1:*}",
            "FROM",
            "    ${2:table_name};"
        ],
        "description": "Basic SELECT",
        "scope": "sql"
    },
    "SQL Select Where": {
        "prefix": "sqlwhere",
        "body": [
            "SELECT",
            "    ${1:*}",
            "FROM",
            "    ${2:table_name}",
            "WHERE",
            "    ${3:column} = ${4:value};"
        ],
        "description": "SELECT with WHERE",
        "scope": "sql"
    },
    "SQL Insert": {
        "prefix": "sqlinsert",
        "body": [
            "INSERT INTO ${1:table_name} (",
            "    ${2:column1},",
            "    ${3:column2}",
            ")",
            "VALUES (",
            "    ${4:value1},",
            "    ${5:value2}",
            ");"
        ],
        "description": "Insert row",
        "scope": "sql"
    },
    "SQL Update": {
        "prefix": "sqlupdate",
        "body": [
            "UPDATE ${1:table_name}",
            "SET",
            "    ${2:column} = ${3:value}",
            "WHERE",
            "    ${4:id} = ${5:value};"
        ],
        "description": "Update row",
        "scope": "sql"
    },
    "SQL Delete": {
        "prefix": "sqldelete",
        "body": [
            "DELETE FROM ${1:table_name}",
            "WHERE ${2:id} = ${3:value};"
        ],
        "description": "Delete row",
        "scope": "sql"
    },
    "SQL Join": {
        "prefix": "sqljoin",
        "body": [
            "SELECT",
            "    ${1:a.*},",
            "    ${2:b.*}",
            "FROM ${3:table_a} a",
            "INNER JOIN ${4:table_b} b",
            "ON a.${5:id} = b.${6:foreign_id};"
        ],
        "description": "Inner Join",
        "scope": "sql"
    },
    "SQL Left Join": {
        "prefix": "sqlleftjoin",
        "body": [
            "SELECT",
            "    ${1:a.*},",
            "    ${2:b.*}",
            "FROM ${3:table_a} a",
            "LEFT JOIN ${4:table_b} b",
            "ON a.${5:id} = b.${6:foreign_id};"
        ],
        "description": "Left Join",
        "scope": "sql"
    },
    "SQL Create View": {
        "prefix": "sqlview",
        "body": [
            "CREATE VIEW ${1:view_name} AS",
            "SELECT",
            "    ${2:*}",
            "FROM",
            "    ${3:table_name}",
            "WHERE",
            "    ${4:condition};"
        ],
        "description": "Create View",
        "scope": "sql"
    },
    "SQL Create Index": {
        "prefix": "sqlindex",
        "body": [
            "CREATE INDEX ${1:index_name}",
            "ON ${2:table_name} (${3:column});"
        ],
        "description": "Create index",
        "scope": "sql"
    },

    
    "PostgreSQL Create Function": {
        "prefix": "pgfunction",
        "body": [
            "CREATE OR REPLACE FUNCTION ${1:function_name}(",
            "    ${2:param1} ${3:TYPE},",
            "    ${4:param2} ${5:TYPE}",
            ")",
            "RETURNS ${6:RETURN_TYPE} AS $$",
            "BEGIN",
            "    ${7:-- logic here}",
            "    RETURN ${8:result};",
            "END;",
            "$$ LANGUAGE plpgsql;"
        ],
        "description": "PostgreSQL function",
        "scope": "sql"
    },
    "PostgreSQL Data Types": {
        "prefix": "pgtypes",
        "body": [
            "-- Numéricos",
            "SMALLINT       -- Entero de 2 bytes (-32768 a 32767)",
            "INTEGER        -- Entero de 4 bytes (predeterminado)",
            "BIGINT         -- Entero de 8 bytes",
            "DECIMAL(p,s)   -- Exactitud fija",
            "NUMERIC(p,s)   -- Exactitud fija (sinónimo de DECIMAL)",
            "REAL           -- Punto flotante de 4 bytes",
            "DOUBLE PRECISION -- Punto flotante de 8 bytes",
            "",
            "-- Caracteres",
            "CHAR(n)        -- Cadena fija de n caracteres",
            "VARCHAR(n)     -- Cadena variable de max n caracteres",
            "TEXT           -- Cadena variable ilimitada",
            "",
            "-- Fechas y Tiempo",
            "DATE           -- Solo fecha",
            "TIME           -- Solo hora",
            "TIMESTAMP      -- Fecha y hora",
            "TIMESTAMPTZ    -- Timestamp con zona horaria",
            "INTERVAL       -- Período de tiempo",
            "",
            "-- Booleanos",
            "BOOLEAN        -- True/False/Null",
            "",
            "-- UUID",
            "UUID           -- Identificador único universal",
            "",
            "-- JSON",
            "JSON           -- Datos JSON",
            "JSONB          -- JSON binario (más rápido)",
            "",
            "-- Arrays",
            "INTEGER[]      -- Array de enteros",
            "TEXT[]         -- Array de texto",
            "",
            "-- Otros",
            "SERIAL         -- Entero auto-incrementable",
            "BIGSERIAL      -- BigInt auto-incrementable",
            "BYTEA          -- Datos binarios",
            "XML            -- Datos XML"
        ],
        "description": "PostgreSQL data types",
        "scope": "sql"
    },
    "MySQL Data Types": {
        "prefix": "mysqltypes",
        "body": [
            "-- Numéricos",
            "TINYINT        -- Entero de 1 byte (-128 a 127)",
            "SMALLINT       -- Entero de 2 bytes",
            "MEDIUMINT      -- Entero de 3 bytes",
            "INT            -- Entero de 4 bytes (predeterminado)",
            "BIGINT         -- Entero de 8 bytes",
            "DECIMAL(p,s)   -- Exactitud fija (p=precision, s=scale)",
            "FLOAT          -- Punto flotante de 4 bytes",
            "DOUBLE         -- Punto flotante de 8 bytes",
            "",
            "-- Cadenas",
            "CHAR(n)        -- Cadena fija de n caracteres (0-255)",
            "VARCHAR(n)     -- Cadena variable (0-65535)",
            "TINYTEXT       -- Hasta 255 caracteres",
            "TEXT           -- Hasta 65535 caracteres",
            "MEDIUMTEXT     -- Hasta 16 MB",
            "LONGTEXT       -- Hasta 4 GB",
            "",
            "-- Binarios",
            "BINARY(n)      -- Cadena binaria fija",
            "VARBINARY(n)   -- Cadena binaria variable",
            "TINYBLOB       -- Hasta 255 bytes",
            "BLOB           -- Hasta 65535 bytes",
            "MEDIUMBLOB     -- Hasta 16 MB",
            "LONGBLOB       -- Hasta 4 GB",
            "",
            "-- Fechas y Tiempo",
            "DATE           -- Fecha (AAAA-MM-DD)",
            "TIME           -- Hora (HH:MM:SS)",
            "DATETIME       -- Fecha y hora (8 bytes)",
            "TIMESTAMP      -- Fecha y hora (4 bytes, con zona horaria)",
            "YEAR           -- Año (4 dígitos)",
            "",
            "-- Otros",
            "BOOLEAN        -- Sinónimo de TINYINT(1)",
            "ENUM(v1,v2,...)-- Valor de lista enumerada",
            "SET(v1,v2,...) -- Conjunto de valores",
            "JSON           -- Datos JSON"
        ],
        "description": "MySQL data types",
        "scope": "sql"
    },
    "SQLite Data Types": {
        "prefix": "sqlitetypes",
        "body": [
            "-- Tipos de datos SQLite (afinidad)",
            "",
            "-- INTEGER (afinidad 1,2,3,4,6,8 bytes)",
            "INTEGER        -- Entero con tamaño variable",
            "TINYINT        -- Entero de 1 byte",
            "SMALLINT       -- Entero de 2 bytes",
            "MEDIUMINT      -- Entero de 3 bytes",
            "BIGINT         -- Entero de 8 bytes",
            "UNSIGNED BIG INT -- Entero sin signo de 8 bytes",
            "",
            "-- REAL (afinidad de punto flotante)",
            "REAL           -- Punto flotante de 8 bytes",
            "DOUBLE         -- Punto flotante de 8 bytes",
            "FLOAT          -- Punto flotante de 4 bytes",
            "",
            "-- TEXT (afinidad de texto)",
            "TEXT           -- Cadena de texto",
            "CHARACTER(n)   -- Cadena de n caracteres",
            "VARCHAR(n)     -- Cadena variable de max n caracteres",
            "NATIVE CHARACTER(n) -- Caracteres nativos",
            "NVARCHAR(n)    -- Unicode variable",
            "",
            "-- BLOB (sin tipo - affinity NONE)",
            "BLOB           -- Datos binarios",
            "NONE           -- Sin tipo específico",
            "",
            "-- NUMERIC (afinidad numérica)",
            "NUMERIC        -- Número genérico",
            "DECIMAL(p,s)   -- Decimal con precisión",
            "BOOLEAN        -- Almacenado como INTEGER (0/1)",
            "DATE           -- Almacenado como TEXT/TYPE actual",
            "DATETIME       -- Almacenado como TEXT/INTEGER/REAL",
            "",
            "-- Notas:",
            "-- SQLite usa tipado dinámico (afinidad), no tipado estricto",
            "-- NULL, CURRENT_TIME, CURRENT_DATE, CURRENT_TIMESTAMP"
        ],
        "description": "SQLite data types",
        "scope": "sql"
    },
    
    "MySQL Dockerfile": {
        "prefix": "mysqldocker",
        "body": [
            "FROM mysql:latest",
            "",
            "# Variables de entorno (ajústalas a tu gusto)",
            "ENV MYSQL_ROOT_PASSWORD=${1:pass1234}",
            "ENV MYSQL_DATABASE=${2:mydb}",
            "ENV MYSQL_USER=${3:diego}",
            "ENV MYSQL_PASSWORD=${4:secret1234}",
            "",
            "# Copia el script de inicialización al directorio de entrada de MySQL",
            "COPY init.sql /docker-entrypoint-initdb.d/",
            "",
            "# Copia el archivo de configuración personalizado",
            "COPY mysqld.cnf /etc/mysql/mysql.conf.d/mysqld.cnf",
            "",
            "# Exponer el puerto 3306",
            "EXPOSE 3306"
        ],
        "description": "MySQL Dockerfile",
        "scope": "sql"
    },
    "MySQL Docker Compose": {
        "prefix": "mysqldcompose",
        "body": [
            "version: '3.8'",
            "services:",
            "  mysql:",
            "    image: mysql:latest",
            "    container_name: ${1:mysql-test}",
            "    environment:",
            "      MYSQL_ROOT_PASSWORD: ${2:pass1234}",
            "      MYSQL_DATABASE: ${3:mydb}",
            "      MYSQL_USER: ${4:diego}",
            "      MYSQL_PASSWORD: ${5:secret1234}",
            "    ports:",
            "      - \"3306:3306\"",
            "    volumes:",
            "      - ./mysqld.cnf:/etc/mysql/mysql.conf.d/mysqld.cnf",
            "      - ./init.sql:/docker-entrypoint-initdb.d/init.sql"
        ],
        "description": "MySQL Docker Compose",
        "scope": "sql"
    }
}