{
    "SQL Create Table": {
        "prefix": "sqlcreate",
        "body": [
            "CREATE TABLE ${1:table_name} (",
            "    id ${2:INT} PRIMARY KEY${3: AUTO_INCREMENT},",
            "    ${4:column_name} ${5:VARCHAR(255)} NOT NULL,",
            "    ${6:created_at} TIMESTAMP DEFAULT CURRENT_TIMESTAMP",
            ");"
        ],
        "description": "Create table",
        "scope": "sql"
    },

    "SQL Select All": {
        "prefix": "postgrefunction",
        "body": [
            "CREATE OR REPLACE FUNCTION buscar_por_letra(letra TEXT)",
            "RETURNS TABLE(",
            "    id INTEGER,",
            "    nombre TEXT,",
            "    dimension TEXT,",
            "    clasificacion TEXT,",
            "    tipo TEXT",
            ") AS $$",
            "BEGIN",
            "    RETURN QUERY",
            "    SELECT",
            "        ai.id,",
            "        i.nombre,",
            "        d.dimension,",
            "        c.clasificacion,",
            "        t.tipo",
            "    FROM all_items ai",
            "    JOIN items i ON ai.nombre_id = i.id",
            "    JOIN dimensiones d ON ai.dimension_id = d.id",
            "    JOIN clasificacion c ON ai.clasificacion_id = c.id",
            "    JOIN tipos_de_items t ON ai.tipo_id = t.id",
            "    WHERE LOWER(i.nombre) LIKE LOWER(letra) || '%';",
            "END;",
            "$$ LANGUAGE plpgsql;",
        ],
        "description": "Funcion postgre",
        "scope": "sql"
    },

    
    "SQL Select All": {
        "prefix": "sqlselect",
        "body": [
            "SELECT",
            "    ${1:*}",
            "FROM",
            "    ${2:table_name};"
        ],
        "description": "Basic SELECT",
        "scope": "sql"
    },
    "SQL Select Where": {
        "prefix": "sqlwhere",
        "body": [
            "SELECT",
            "    ${1:*}",
            "FROM",
            "    ${2:table_name}",
            "WHERE",
            "    ${3:column} = ${4:value};"
        ],
        "description": "SELECT with WHERE",
        "scope": "sql"
    },
    "SQL Insert": {
        "prefix": "sqlinsert",
        "body": [
            "INSERT INTO ${1:table_name} (",
            "    ${2:column1},",
            "    ${3:column2}",
            ")",
            "VALUES (",
            "    ${4:value1},",
            "    ${5:value2}",
            ");"
        ],
        "description": "Insert row",
        "scope": "sql"
    },
    "SQL Update": {
        "prefix": "sqlupdate",
        "body": [
            "UPDATE ${1:table_name}",
            "SET",
            "    ${2:column} = ${3:value}",
            "WHERE",
            "    ${4:id} = ${5:value};"
        ],
        "description": "Update row",
        "scope": "sql"
    },
    "SQL Delete": {
        "prefix": "sqldelete",
        "body": [
            "DELETE FROM ${1:table_name}",
            "WHERE ${2:id} = ${3:value};"
        ],
        "description": "Delete row",
        "scope": "sql"
    },
    "SQL Join": {
        "prefix": "sqljoin",
        "body": [
            "SELECT",
            "    ${1:a.*},",
            "    ${2:b.*}",
            "FROM ${3:table_a} a",
            "INNER JOIN ${4:table_b} b",
            "ON a.${5:id} = b.${6:foreign_id};"
        ],
        "description": "Inner Join",
        "scope": "sql"
    },
    "SQL Left Join": {
        "prefix": "sqlleftjoin",
        "body": [
            "SELECT",
            "    ${1:a.*},",
            "    ${2:b.*}",
            "FROM ${3:table_a} a",
            "LEFT JOIN ${4:table_b} b",
            "ON a.${5:id} = b.${6:foreign_id};"
        ],
        "description": "Left Join",
        "scope": "sql"
    },
    "SQL Create View": {
        "prefix": "sqlview",
        "body": [
            "CREATE VIEW ${1:view_name} AS",
            "SELECT",
            "    ${2:*}",
            "FROM",
            "    ${3:table_name}",
            "WHERE",
            "    ${4:condition};"
        ],
        "description": "Create View",
        "scope": "sql"
    },
    "SQL Create Index": {
        "prefix": "sqlindex",
        "body": [
            "CREATE INDEX ${1:index_name}",
            "ON ${2:table_name} (${3:column});"
        ],
        "description": "Create index",
        "scope": "sql"
    },

    
    "MySQL Dockerfile": {
        "prefix": "mysqldocker",
        "body": [
            "FROM mysql:latest",
            "",
            "# Variables de entorno (ajústalas a tu gusto)",
            "ENV MYSQL_ROOT_PASSWORD=${1:pass1234}",
            "ENV MYSQL_DATABASE=${2:mydb}",
            "ENV MYSQL_USER=${3:diego}",
            "ENV MYSQL_PASSWORD=${4:secret1234}",
            "",
            "# Copia el script de inicialización al directorio de entrada de MySQL",
            "COPY init.sql /docker-entrypoint-initdb.d/",
            "",
            "# Copia el archivo de configuración personalizado",
            "COPY mysqld.cnf /etc/mysql/mysql.conf.d/mysqld.cnf",
            "",
            "# Exponer el puerto 3306",
            "EXPOSE 3306"
        ],
        "description": "MySQL Dockerfile",
        "scope": "sql"
    },
    "MySQL Docker Compose": {
        "prefix": "mysqldcompose",
        "body": [
            "version: '3.8'",
            "services:",
            "  mysql:",
            "    image: mysql:latest",
            "    container_name: ${1:mysql-test}",
            "    environment:",
            "      MYSQL_ROOT_PASSWORD: ${2:pass1234}",
            "      MYSQL_DATABASE: ${3:mydb}",
            "      MYSQL_USER: ${4:diego}",
            "      MYSQL_PASSWORD: ${5:secret1234}",
            "    ports:",
            "      - \"3306:3306\"",
            "    volumes:",
            "      - ./mysqld.cnf:/etc/mysql/mysql.conf.d/mysqld.cnf",
            "      - ./init.sql:/docker-entrypoint-initdb.d/init.sql"
        ],
        "description": "MySQL Docker Compose",
        "scope": "sql"
    }
}
